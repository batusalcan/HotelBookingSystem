{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [ { "Name": "Console" } ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "MongoDB": "YOUR_MONGODB_CONNECTION_STRING"
  },
  "MongoDB": {
    "DatabaseName": "HotelBookingDb",
    "CollectionName": "hotelReviews"
  },
  "AllowedHosts": "*"
}
