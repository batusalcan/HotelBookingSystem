{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId:l}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "RabbitMQ": {
    "Host": "YOUR_RABBITMQ_HOST",
    "Port": 5671,
    "Username": "YOUR_RABBITMQ_USERNAME",
    "Password": "YOUR_RABBITMQ_PASSWORD",
    "VirtualHost": "YOUR_RABBITMQ_VHOST",
    "Ssl": "true",
    "Exchange": "hotel.reservations",
    "Queue": "reservation.created",
    "RoutingKey": "reservation.created"
  },
  "HotelService": {
    "BaseUrl": "https://hotel-hotelservice-aje8f7f7dqb5f0a5.italynorth-01.azurewebsites.net"
  },
  "ConnectionStrings": {
    "NotificationsDb": "Host=YOUR_SUPABASE_HOST;Port=5432;Database=postgres;Username=YOUR_SUPABASE_USER;Password=YOUR_PASSWORD;SSL Mode=Require"
  },
  "AllowedHosts": "*"
}
