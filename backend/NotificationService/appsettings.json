{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [ { "Name": "Console" } ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "SqlServer": "Server=YOUR_SERVER;Database=HotelCatalogDb;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  },
  "RabbitMQ": {
    "Host": "YOUR_RABBITMQ_HOST",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "Exchange": "hotel.reservations",
    "Queue": "reservation.created",
    "RoutingKey": "reservation.created"
  },
  "AllowedHosts": "*"
}
