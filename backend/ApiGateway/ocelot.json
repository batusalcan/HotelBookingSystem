  "SwaggerEndPoints": [
    {
      "Key": "hotelservice",
      "Config": [
        {
          "Name": "Hotel Service",
          "Version": "v1",
          "Url": "http://localhost:5200/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "commentsservice",
      "Config": [
        {
          "Name": "Comments Service",
