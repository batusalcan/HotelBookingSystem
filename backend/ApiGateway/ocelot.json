      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 5200 } ],
      "SwaggerKey": "hotelservice",
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      },
      "RateLimitOptions": { "EnableRateLimiting": false }
    },

    {
      "UpstreamPathTemplate": "/gateway/v1/admin/hotels",
      "UpstreamHttpMethod": [ "GET", "POST" ],
      "DownstreamPathTemplate": "/api/v1/admin/hotels",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [ { "Host": "localhost", "Port": 5200 } ],
      "SwaggerKey": "hotelservice",
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      },
      "RateLimitOptions": { "EnableRateLimiting": false }
    },

