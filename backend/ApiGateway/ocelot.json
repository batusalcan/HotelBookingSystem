          "Url": "http://localhost:5160/swagger/v1/swagger.json"
        }
      ]
    }
  ],

  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5158",
    "RateLimitOptions": {
      "ClientIdHeader": "X-Client-IP",
      "QuotaExceededMessage": "Too many requests. Please try again later.",
