{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [ { "Name": "Console" } ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "CatalogDb": "Server=YOUR_SERVER;Database=HotelCatalogDb;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;",
    "BookingDb": "Server=YOUR_SERVER;Database=HotelBookingDb;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;",
    "Redis": "YOUR_REDIS_CONNECTION_STRING"
  },
  "Jwt": {
    "Authority": "YOUR_SUPABASE_OR_FIREBASE_URL",
    "Audience": "YOUR_AUDIENCE"
  },
  "Cache": {
    "SearchTtlMinutes": 15,
    "HotelDetailTtlMinutes": 60
  },
  "RabbitMQ": {
    "Host": "YOUR_RABBITMQ_HOST",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "Exchange": "hotel.reservations",
    "Queue": "reservation.created",
    "RoutingKey": "reservation.created"
  },
  "AllowedHosts": "*"
}
