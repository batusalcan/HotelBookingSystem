{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [ { "Name": "Console" } ],
    "Enrich": [ "FromLogContext" ]
  },
  "Jwt": {
    "Authority": "YOUR_SUPABASE_OR_FIREBASE_URL",
    "Audience": "YOUR_AUDIENCE"
  },
  "Anthropic": {
    "ApiKey": "YOUR_ANTHROPIC_API_KEY",
    "Model": "claude-sonnet-4-6"
  },
  "ServiceUrls": {
    "HotelSearch": "http://localhost:5002",
    "BookHotel": "http://localhost:5003"
  },
  "AllowedHosts": "*"
}
